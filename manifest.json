{
  "manifest_version": 3,
  "name": "Amethyst",
  "version": "1.2.3",
  "description": "i-Ready Study Tool",
  "permissions": [
    "sidePanel",
    "scripting",
    "activeTab",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>",
    "https://generativelanguage.googleapis.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "popup.html"
  },
  "action": {
    "default_title": "Amethyst"
  },
  "web_accessible_resources": [
    {
      "resources": ["marked.min.js"],
      "matches": ["<all_urls>"]
    }
  ]
   "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  }
}
